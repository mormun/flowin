# ============================================
# Configuración de la base de datos
# ============================================
POSTGRES_USER=flowin
POSTGRES_PASSWORD=flowin
POSTGRES_DB=flowindb

# URL completa que usa Prisma
# - En Docker: usar el nombre del servicio (postgres)
# - En desarrollo local sin Docker: usar localhost
DATABASE_URL="postgresql://flowin:flowin@localhost:5432/flowindb"

# ============================================
# NextAuth
# ============================================
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=

NEXTAUTH_URL=http://localhost:3000

# ============================================
# Google OAuth
# ============================================
# Obtener en https://console.cloud.google.com → APIs y servicios → Credenciales
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=