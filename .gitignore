# Ver https://help.github.com/articles/ignoring-files/

# Dependencias de Node
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Cobertura de tests
/coverage

# Build de Next.js
/.next/
/out/

# Build de producción
/build

# Miscelánea
.DS_Store
*.pem

# Logs de debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Variables de entorno — excluir todo excepto el ejemplo
.env*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Cliente generado por Prisma — se regenera con "prisma generate"
/src/generated/prisma

# Archivos subidos por usuarios en local (Docker) — no subir al repo
/public/uploads