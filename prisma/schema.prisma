generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model attachments {
  id         Int       @id @default(autoincrement())
  ticket_id  Int
  filename   String?   @db.VarChar(255)
  file_path  String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  tickets    tickets   @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ticket_attachment")
}

model categories {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?
  active      Boolean?  @default(true)
  tickets     tickets[]
}

model comments {
  id         Int       @id @default(autoincrement())
  ticket_id  Int
  user_id    Int?
  content    String?
  is_system  Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  tickets    tickets   @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ticket")
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user")
}

model status {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(50)
  description String?
  active      Boolean?  @default(true)
  tickets     tickets[]
}

model tickets {
  id                               Int             @id @default(autoincrement())
  title                            String          @db.VarChar(150)
  description                      String?
  category_id                      Int?
  status_id                        Int?
  priority                         String?         @db.VarChar(20)
  created_by                       Int?
  assigned_to                      Int?
  created_at                       DateTime?       @default(now()) @db.Timestamp(6)
  updated_at                       DateTime?       @db.Timestamp(6)
  closed_at                        DateTime?       @db.Timestamp(6)
  attachments                      attachments[]
  comments                         comments[]
  notifications                    notifications[]
  users_tickets_assigned_toTousers users?          @relation("tickets_assigned_toTousers", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_assigned_to")
  categories                       categories?     @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_category")
  users_tickets_created_byTousers  users?          @relation("tickets_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_created_by")
  status                           status?         @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_status")
}

model users {
  id                                 Int             @id @default(autoincrement())
  name                               String?         @db.VarChar(80)
  surname                            String?         @db.VarChar(100)
  email                              String          @unique @db.VarChar(150)
  role                               String?         @default("user") @db.VarChar(20)
  active                             Boolean?        @default(true)
  password_hash                      String?          @db.VarChar(255)
  registration_date                  DateTime?       @default(now()) @db.Timestamp(6)
  comments                           comments[]
  notifications                      notifications[]
  tickets_tickets_assigned_toTousers tickets[]       @relation("tickets_assigned_toTousers")
  tickets_tickets_created_byTousers  tickets[]       @relation("tickets_created_byTousers")
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String
  message    String
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  ticket_id  Int?

  ticket     tickets? @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_ticket")
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_user")
}
